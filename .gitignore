# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip
# ...except the Gradle wrapper jar, required for `./gradlew` to run at all
!android-twa/gradle/wrapper/gradle-wrapper.jar

# Logs and databases #
######################
*.log
*.sql
*.sqlite
# ...except Drizzle migration files, which are checked-in source, not dumps
!server/drizzle/**/*.sql

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node / build artifacts #
###########################
node_modules/
dist/
.env
*.local
*.tsbuildinfo

# Android TWA — never commit the signing keystore or local build output.
# The keystore is the app's identity for its entire lifetime on the Play
# Store; it must only ever live in GitHub Actions secrets and a private
# backup, never in this (public) repo.
android-twa/*.keystore
android-twa/local.properties
android-twa/.gradle/
android-twa/app/build/
android-twa/build/
android-twa/captures/
android-twa/.idea/
android-twa/*.iml
