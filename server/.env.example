# Postgres connection
DATABASE_URL=postgresql://app:app@localhost:5432/recon_dev

# Session
SESSION_SECRET=change-me-in-production

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# OTP delivery — leave unset to use the console/dev provider (logs OTP to server stdout)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
AFRICASTALKING_SENDER_ID=

# Super-admin bootstrap (created on first migrate if no super-admin exists)
SUPERADMIN_USERNAME=pitsadmin
SUPERADMIN_PASSWORD=change-me-in-production

# Paystack billing — leave unset to disable billing routes (they fail cleanly;
# the rest of the app, including the trial itself, still works). No separate
# webhook-signing secret — Paystack signs with the same secret key.
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_CODE_MONTHLY=
PAYSTACK_PLAN_CODE_ANNUAL=
# Premium add-on (financial statements + payroll) — a second, always-monthly
# Paystack subscription. Leave unset to disable the add-on checkout route.
PAYSTACK_PLAN_CODE_ADDON_MONTHLY=
PAYSTACK_PLAN_CODE_ADDON_ANNUAL_EXTRA=

# Gmail statement-inbox integration — leave unset to disable (the Email inbox
# page still loads, just shows "not configured"). Create these in Google Cloud
# Console: OAuth 2.0 Client ID (Web application), redirect URI
# <your-app-origin>/api/email-integrations/gmail/callback, Gmail API enabled.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Symmetric key used to encrypt Gmail OAuth tokens at rest (AES-256-GCM via
# scrypt). Any long random string — generate with e.g. `openssl rand -hex 32`.
ENCRYPTION_KEY=

# AI-assisted expense entry (Premium add-on) — leave unset to disable; the
# "Add expense" form still works manually, just without document scan/voice.
# Get a key from https://console.anthropic.com. Every scanned document or
# voice transcript is sent to Anthropic's API for processing — see README.
ANTHROPIC_API_KEY=

# Optional: cap the pg pool per serverless instance (see server/src/db/index.ts)
PG_POOL_MAX=5
